// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tambahkan Enum baru untuk menyelaraskan dengan status webhook Midtrans
enum PaymentStatus {
  PENDING
  SETTLEMENT // Pembayaran berhasil
  EXPIRE // Waktu bayar habis
  CANCEL // Dibatalkan pengguna/sistem
  DENY // Ditolak oleh fraud detection Midtrans
  REFUND // Dana dikembalikan
}

// Enum untuk membatasi nilai yang valid pada sistem
enum Role {
  ADMIN
  FAMILY // Akun keluarga yang memesan
  NURSE // Perawat / Caregiver
}

enum ServiceType {
  VISIT
  LIVE_IN
  LIVE_OUT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
}

enum ServiceName {
  MEDIS
  NON_MEDIS
}

// Model utama untuk autentikasi dan otorisasi pengguna
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phoneNumber  String
  role         Role     @default(FAMILY)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relasi: Satu akun keluarga bisa memiliki banyak data lansia
  patients Patient[]

  // Relasi: Jika user adalah perawat, dia memiliki profil khusus
  nurseProfile NurseProfile?
}

// Model untuk data lansia yang dirawat
model Patient {
  id             String   @id @default(uuid())
  familyId       String
  family         User     @relation(fields: [familyId], references: [id])
  name           String
  dateOfBirth    DateTime
  weight         Float?
  height         Float?
  medicalHistory String? // Kondisi bawaan (diabetes, hipertensi, dll)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments Appointment[]
  medicalLogs  CareLog[]
}

// Model untuk melengkapi portofolio dan rating perawat
model NurseProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  specialization  String // Contoh: "Perawatan Luka Gangren", "Caregiver ADL"
  experienceYears Int
  rating          Float   @default(0.0)
  isVerified      Boolean @default(false)

  appointments Appointment[]
  careLogs     CareLog[]
}

// Model transaksi dan penjadwalan layanan
model Appointment {
  id        String       @id @default(uuid())
  patientId String
  patient   Patient      @relation(fields: [patientId], references: [id])
  nurseId   String
  nurse     NurseProfile @relation(fields: [nurseId], references: [id])

  serviceType ServiceType
  serviceName ServiceName
  status      AppointmentStatus @default(PENDING)

  // Properti ini mendefinisikan batas waktu atau tenggat pelaksanaan layanan.
  // Didefinisikan secara eksplisit tanpa tanda tanya (?) agar mandatory (wajib diisi/tidak mungkin kosong) 
  // saat sebuah record pemesanan baru dibuat di sistem.
  dueDate    DateTime
  totalPrice Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careLogs CareLog[]

  // Relasi ke tabel pembayaran
  payments Payment[]
}

// Model baru khusus untuk melacak riwayat pembayaran Midtrans
model Payment {
  id String @id @default(uuid())

  // Relasi ke Appointment
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  // WAJIB: Ini yang Anda kirimkan sebagai 'order_id' saat hit API Midtrans.
  // Jangan gunakan appointmentId, gunakan paymentId (atau midtransOrderId ini)
  midtransOrderId String @unique

  amount Float
  status PaymentStatus @default(PENDING)

  // Menyimpan cara bayar (misal: "bca_va", "gopay", "credit_card")
  // Diisi setelah webhook Midtrans masuk
  paymentMethod String?

  // Opsional namun direkomendasikan jika Anda menggunakan Midtrans Snap
  // Berguna untuk me-render halaman pembayaran di frontend
  snapToken       String?
  snapRedirectUrl String?

  paidAt    DateTime? // Waktu pasti kapan uang masuk
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([appointmentId])
}

// Model untuk fitur "Laporan Digital Real-time" dan checklist harian
model CareLog {
  id String @id @default(uuid())

  // Relasi Data
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  nurseId String
  nurse   NurseProfile @relation(fields: [nurseId], references: [id])

  // Metrik Vital (Opsional / Nullable)
  systolic    Int? // Tekanan darah atas (misal: 120)
  diastolic   Int? // Tekanan darah bawah (misal: 80)
  bloodSugar  Float? // Gula darah dalam mg/dL
  cholesterol Float? // Kolesterol dalam mg/dL
  uricAcid    Float? // Asam urat dalam mg/dL

  // Observasi Klinis & Psikologis
  woundCondition String? // Observasi dari item "Cek Luka Jatuh"
  moodScore      Int? // Skala 1-5 untuk grafik mood pasien
  clinicalNotes  String? @db.Text // Menggunakan db.Text untuk memfasilitasi catatan panjang perawat

  // Log aktivitas perawat
  activityLog ActivityLog[]

  // Timestamp
  recordedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Indexing untuk performa kueri grafik
  @@index([patientId, recordedAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  notes     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  careLogId String
  careLog   CareLog @relation(fields: [careLogId], references: [id])
}
